# Variables de entorno para integration tests
# DB separada de dev — evita contaminar datos locales con test runs.
# docker-compose expone postgres en el puerto 5433 del host.
DB_HOST=localhost
DB_PORT=5433
DB_USER=finance_user
DB_PASSWORD=finance_password
DB_NAME=personal_finance_db_test
DB_SYNCHRONIZE=false

JWT_SECRET=test-jwt-secret-do-not-use-in-production
JWT_REFRESH_SECRET=test-jwt-refresh-secret-do-not-use-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=3001

# Throttle desactivado de facto en test: la suite registra muchos usuarios
# desde la misma IP (127.0.0.1) en segundos. Con el límite de prod (5/min auth)
# la propia suite se auto-bloquea con 429. Subimos el techo solo para tests.
THROTTLE_LIMIT=1000000
THROTTLE_TTL=60000
THROTTLE_AUTH_LIMIT=1000000
THROTTLE_AUTH_TTL=60000

# Redis — usar la misma instancia dev (tests de integración)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_KEY_PREFIX=pf:test:
