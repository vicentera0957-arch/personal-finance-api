# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=finance_user
DB_PASSWORD=finance_password
DB_NAME=personal_finance_db
# synchronize: true SOLO en dev. En prod usar migraciones.
DB_SYNCHRONIZE=true
DB_LOGGING=false
# TLS hacia la DB. true en Postgres gestionado (Neon/Supabase/RDS).
DB_SSL=false
# Poner false solo si la DB usa certificado self-signed.
DB_SSL_REJECT_UNAUTHORIZED=true
# Pool de conexiones por instancia y timeout de conexión (ms).
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT_MS=10000

# JWT — genera valores aleatorios seguros para producción
# Ejemplo: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-in-production-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — coma-separado, '*' solo para dev local.
# En production NO se permite '*' (la app no arranca): poné dominios explícitos.
CORS_ORIGIN=*

# Proxies de confianza delante de la app (LB / reverse proxy).
# 0 = ninguno (dev). En prod detrás de un balanceador: 1 (o el nº de proxies).
TRUST_PROXY=0

# Rate limiting (requests por IP)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# Más estricto para /auth/*
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=5

# Redis — cache y throttler storage
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=  # dejar vacío en dev sin auth
REDIS_KEY_PREFIX=pf:

# Swagger (/api/docs)
SWAGGER_ENABLED=true
